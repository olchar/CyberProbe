    %% === STYLES ===
    classDef source fill:#1f6feb,stroke:#58a6ff,color:#fff,stroke-width:2px
    classDef domain fill:#238636,stroke:#3fb950,color:#fff,stroke-width:2px,rx:8
    classDef method fill:#21262d,stroke:#30363d,color:#c9d1d9,stroke-width:2px
